{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "allowSyntheticDefaultImports": true,
    "noEmit": true
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "src/ai/aiIntentContract.ts",
    "src/ai/svgArtworkContract.ts",
    "src/ai/deepSeekIntentProxy.ts",
    "src/domain/types.ts",
    "netlify/functions/**/*.ts"
  ]
}
